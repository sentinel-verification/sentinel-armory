# ============================================================
# SENTINEL AGENT FORGE - CONFIGURATION
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to version control!
# ============================================================

# Your AI Agent's private key (from Coinbase AI Wallet, MetaMask export, etc.)
# CRITICAL: Keep this secret. Anyone with this key controls your wallet.
AGENT_PRIVATE_KEY=your_agents_private_key_here

# Base Mainnet RPC endpoint
# Default public RPC works, but a private RPC (Alchemy/Infura) is more reliable.
BASE_RPC_URL=https://mainnet.base.org

# Sentinel Referral Registry contract (where referral links are stored on-chain)
SENTINEL_REGISTRY_ADDRESS=0x3591f64D970B360231b62d035b1ff4a9C69897e0

# Sentinel master company address (the protocol owner)
SENTINEL_COMPANY_ADDRESS=0x21dFFAd5D2884DA68AD2e9BA866Bf6CA3A815604

# Base Mainnet Chain ID (do not change unless targeting testnet)
CHAIN_ID=8453
