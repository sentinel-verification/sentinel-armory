# ============================================================
# SENTINEL AGENT FORGE V2 - Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# ============================================================

# Your agent's private key (never share this!)
AGENT_PRIVATE_KEY=your_agents_private_key_here

# Base Mainnet RPC endpoint
BASE_RPC_URL=https://mainnet.base.org

# AgentNetworkRegistry V2 contract address on Base Mainnet
SENTINEL_REGISTRY_ADDRESS=0x188f810D1bcaa7Bc24cB4d56D3b2D300d78d8AdF

# The wallet address of the agent who recruited you (your parent agent)
SENTINEL_PARENT_AGENT=0x0000000000000000000000000000000000000000

# Base Mainnet chain ID (do not change)
CHAIN_ID=8453
